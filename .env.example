# WA Convo v4.2 — WhatsApp Automation Platform
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1

# ─── Authentication ───────────────────────────────────────────────────────────
# Bearer token for API authentication. Leave empty to disable (dev only)
API_KEY=

# ─── Clients ──────────────────────────────────────────────────────────────────
# Number of WhatsApp client slots to create (1-6)
CLIENT_COUNT=6

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite database path (relative to project root)
# DATABASE_PATH=./data/wa-convo.db
# Retention: auto-delete records older than N days
# DATABASE_RETENTION_DAYS=30

# ─── Webhook (Legacy — use /webhooks API instead) ────────────────────────────
# Auto-migrated to webhook system on first startup
# WEBHOOK_URL=

# ─── Meta Cloud API ──────────────────────────────────────────────────────────
# App secret for HMAC signature verification on incoming Meta webhooks
# META_APP_SECRET=
# Verify token for Meta webhook hub verification
# WHATSAPP_VERIFY_TOKEN=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Max requests per IP per minute
RATE_LIMIT_MAX=60

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── AI Integration ──────────────────────────────────────────────────────────
# Configure in config/config.json for full control, or use env vars:
# AI_ENABLED=false
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...

# ─── SSL / TLS ───────────────────────────────────────────────────────────────
# SSL_ENABLED=false
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
