# WA Convo — WhatsApp Automation Platform
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1

# ─── Authentication ───────────────────────────────────────────────────────────
# Bearer token for API authentication. Leave empty to disable (dev only)
API_KEY=

# ─── Clients ──────────────────────────────────────────────────────────────────
# Number of WhatsApp client slots to create
CLIENT_COUNT=6

# ─── Webhook ──────────────────────────────────────────────────────────────────
# URL to forward incoming messages to (optional)
WEBHOOK_URL=
# Legacy alias for WEBHOOK_URL
POST_API=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Max requests per IP per minute
RATE_LIMIT_MAX=60

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── AI Integration (Phase 2) ─────────────────────────────────────────────────
# AI_ENABLED=false
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# ─── Dashboard (Phase 2) ──────────────────────────────────────────────────────
# DASHBOARD_ENABLED=false
# DASHBOARD_PORT=3001

# ─── Deployment ───────────────────────────────────────────────────────────────
# PUBLIC_URL=https://your-server.com
# SSL_ENABLED=false
# SSL_CERT_PATH=
# SSL_KEY_PATH=
