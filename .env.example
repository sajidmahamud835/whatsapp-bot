# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Auth ────────────────────────────────────────────────────────────────────
# Set a strong secret. All API endpoints require: Authorization: Bearer <API_KEY>
# Leave empty to disable auth (not recommended for production)
API_KEY=your_secret_api_key_here

# ─── WhatsApp Clients ─────────────────────────────────────────────────────────
# Number of WhatsApp client slots to create (default: 6)
CLIENT_COUNT=6

# ─── Webhook ─────────────────────────────────────────────────────────────────
# URL to POST incoming messages to (optional)
# Your server should return JSON: { "reply": "text", "replyMedia": "base64..." }
WEBHOOK_URL=https://your-server.com/webhook

# ─── CORS ────────────────────────────────────────────────────────────────────
# Allowed origins. Use * for all (default) or a specific origin
CORS_ORIGIN=*

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Max requests per IP per minute (default: 60)
RATE_LIMIT_MAX=60

# ─── Legacy (deprecated — use WEBHOOK_URL instead) ───────────────────────────
# POST_API=https://your-server.com/webhook.php
