  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sajidmahamud835/whatsapp-bot.git"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "api",
    "typescript",
    "multi-client",
    "baileys",
    "websocket"
  ],
  "bugs": {
    "url": "https://github.com/sajidmahamud835/whatsapp-bot/issues"
  },
  "homepage": "https://github.com/sajidmahamud835/whatsapp-bot#readme",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.18",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pino": "^9.6.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/qrcode-terminal": "^0.12.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
