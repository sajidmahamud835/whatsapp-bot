{
  "name": "whatsapp-bot",
  "version": "3.0.0",
  "description": "WhatsApp unofficial multi-client REST API powered by Baileys (WebSocket-based, no Puppeteer).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only --esm src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "engines": {
    "node": ">=18"
  },
  "jest": {
    "reporters": [
      "default"
    ]
  },
